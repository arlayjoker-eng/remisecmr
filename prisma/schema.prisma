// RemiseCMR v2 — kiosque iPad · Collège Mont-Royal
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  STAFF_MANAGER
  OPERATOR
}

enum LaptopStatus {
  PENDING
  DELIVERED
}

enum LockerStatus {
  AVAILABLE
  DELIVERED
}

enum DeliveryType {
  LAPTOP
  CASIER
}

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  passwordHash        String
  fullName            String
  role                Role       @default(OPERATOR)
  active              Boolean    @default(true)
  accessLaptopReports Boolean    @default(false) // rapports Portables
  accessCasierReports Boolean    @default(true) // rapports Casiers
  accessReception     Boolean    @default(false) // poste réception
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deliveries          Delivery[]
}

model Student {
  id                      String       @id @default(cuid())
  studentNumber           String       @unique // = code-barres
  firstName               String
  lastName                String
  email                   String?
  group                   String // "Sec 1A"
  level                   String // "1".."5"
  boxNumber               String?
  laptopSerial            String?
  laptopModel             String?
  laptopStatus            LaptopStatus @default(PENDING)
  receivesLaptop          Boolean      @default(false)
  receivesLocker          Boolean      @default(false)
  assignedLockerNumber    String? // casier de A (du CSV)
  assignedCombinationCode String?
  petitCasier             String? // saisie manuelle depuis /reports
  lockerDeliveredAt       DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  deliveries              Delivery[]
  lockerAsA               Locker?      @relation("LockerOfA")
  lockerAsB               Locker?      @relation("LockerOfB")
  annonce                 Annonce?
}

// Annonce — préavis de la réception vers le poste de remise des portables.
model Annonce {
  id           String   @id @default(cuid())
  studentId    String   @unique
  announcedAt  DateTime @default(now())
  announcedBy  String // userId
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Locker {
  id                     String       @id @default(cuid())
  number                 String       @unique
  serialNumber           String? // n° de série du cadenas/loker
  combinationCode        String
  assignedStudentNumberA String?      @unique // alumno A (du CSV)
  studentA               Student?     @relation("LockerOfA", fields: [assignedStudentNumberA], references: [studentNumber])
  assignedStudentNumberB String?      @unique // binôme — choisi par les opérateurs
  studentB               Student?     @relation("LockerOfB", fields: [assignedStudentNumberB], references: [studentNumber])
  status                 LockerStatus @default(AVAILABLE)
  delivery               Delivery?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model AuditLog {
  id       String   @id @default(cuid())
  at       DateTime @default(now())
  userId   String
  userName String
  action   String // ex. "casier.edit", "casier.remise"
  target   String // ex. n° d'élève ou n° de casier
  details  String // résumé lisible du changement
}

model Delivery {
  id             String       @id @default(cuid())
  type           DeliveryType
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  operatorId     String
  operator       User         @relation(fields: [operatorId], references: [id])
  lockerId       String?      @unique
  locker         Locker?      @relation(fields: [lockerId], references: [id])
  folio          String?      @unique // laptops seulement
  tutorNameTyped String? // laptops seulement
  tutorIdLast4   String?
  signaturePng   Bytes?
  pdfPath        String?
  pdfSha256      String?
  deliveredAt    DateTime     @default(now())

  @@unique([studentId, type])
}
