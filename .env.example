# Copy to .env and adjust for your environment.

# Dev:  file:./dev.db        (relative to prisma/)
# VPS:  file:/var/lib/remisecmr/db.sqlite
DATABASE_URL="file:./dev.db"

# Dev:  ./pdfs
# VPS:  /var/lib/remisecmr/pdfs
PDF_DIR="./pdfs"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Chiffrement au repos (signature + tutorIdLast4). 32 octets base64.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# Compte SUPER_ADMIN initial (obligatoire pour le seed — aucun défaut en code).
SUPER_ADMIN_EMAIL=""
SUPER_ADMIN_PASSWORD=""
