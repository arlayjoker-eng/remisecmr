# Copy to .env and adjust for your environment.

# Dev:  file:./dev.db        (relative to prisma/)
# VPS:  file:/var/lib/remisecmr/db.sqlite
DATABASE_URL="file:./dev.db"

# Dev:  ./pdfs
# VPS:  /var/lib/remisecmr/pdfs
PDF_DIR="./pdfs"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Chiffrement au repos (signature + tutorIdLast4). 32 octets base64.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# Compte SUPER_ADMIN initial (obligatoire pour le seed — aucun défaut en code).
SUPER_ADMIN_EMAIL=""
SUPER_ADMIN_PASSWORD=""

# --- Synchronisation depuis cmr-device-manager (flux PORTABLE) ------------
# cmr-device-manager tourne sur le portable de l'admin et POUSSE les élèves
# vers POST /api/sync/students avec l'en-tête X-Sync-Key.
# La MÊME valeur doit figurer dans le .env du backend cmr-device-manager.
# Générer avec :  openssl rand -base64 32
# Laisser vide DÉSACTIVE l'endpoint (503) — il ne s'ouvre jamais sans clé.
SYNC_SECRET=""
