# Copy to .env and adjust for your environment.

# Dev:  file:./dev.db        (relative to prisma/)
# VPS:  file:/var/lib/remisecmr/db.sqlite
DATABASE_URL="file:./dev.db"

# Dev:  ./pdfs
# VPS:  /var/lib/remisecmr/pdfs
PDF_DIR="./pdfs"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
